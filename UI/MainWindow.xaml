<Window x:Class="EmailParser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        mc:Ignorable="d"
        Title="Email Parser" Height="940" Width="1120" Icon="pack://application:,,,/myico.ico"
    WindowStartupLocation="CenterScreen"
    ui:WindowHelper.UseModernWindowStyle="True"
    Loaded="Window_Loaded"
    Background="{DynamicResource SystemControlBackgroundAltHighBrush}">

    <Window.Resources>
        <Style x:Key="TopTabToggleStyle" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeLowBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAccentBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundAccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundAltHighBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource TopTabToggleStyle}">
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="MinHeight" Value="72" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeLowBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundAltHighBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="84" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.9*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="0.85*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:SimpleStackPanel Grid.Row="1" Grid.Column="0" Grid.RowSpan="3" Orientation="Vertical" Spacing="10" HorizontalAlignment="Center">
            <ToggleButton x:Name="CheckerTab" Style="{StaticResource NavToggleStyle}" Checked="CheckerTab_Checked">
                <ui:SymbolIcon Symbol="Contact" />
            </ToggleButton>
            <ToggleButton x:Name="HotmailTab" Style="{StaticResource NavToggleStyle}" Checked="HotmailTab_Checked">
                <TextBlock Text="H" FontWeight="Bold" />
            </ToggleButton>
            <ToggleButton x:Name="UploadTab" Style="{StaticResource NavToggleStyle}" Checked="UploadTab_Checked">
                <TextBlock Text="M" FontWeight="Bold" />
            </ToggleButton>
            <ToggleButton x:Name="OneDriveTab" Style="{StaticResource NavToggleStyle}" Checked="OneDriveTab_Checked" IsEnabled="False">
                <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
            </ToggleButton>
            <ToggleButton x:Name="CryptoKeyTab" Style="{StaticResource NavToggleStyle}" Checked="CryptoKeyTab_Checked" IsEnabled="False">
                <Viewbox Width="24" Height="24">
                    <Canvas Width="24" Height="24">
                        <Polygon Points="12,2.4 18.6,6.2 18.6,13.8 12,17.6 5.4,13.8 5.4,6.2"
                                 Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"
                                 StrokeThickness="1.8"
                                 StrokeLineJoin="Round" />
                        <Ellipse Width="4.4" Height="4.4"
                                 Canvas.Left="9.8" Canvas.Top="6.8"
                                 Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" />
                        <Rectangle Width="2.2" Height="5.7"
                                   Canvas.Left="10.9" Canvas.Top="10.2"
                                   RadiusX="0.9" RadiusY="0.9"
                                   Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" />
                        <Line X1="16.8" Y1="5.1" X2="20.1" Y2="3.1"
                              Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"
                              StrokeThickness="1.6"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <Ellipse Width="2.4" Height="2.4"
                                 Canvas.Left="19.5" Canvas.Top="1.9"
                                 Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" />
                        <Line X1="7.2" Y1="15.1" X2="4.1" Y2="17.2"
                              Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"
                              StrokeThickness="1.6"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <Ellipse Width="2.4" Height="2.4"
                                 Canvas.Left="2.4" Canvas.Top="16.3"
                                 Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" />
                    </Canvas>
                </Viewbox>
            </ToggleButton>
            <!-- Anti-Public tab — eye icon -->
            <ToggleButton x:Name="AntiPublicTab" Style="{StaticResource NavToggleStyle}" Checked="AntiPublicTab_Checked" IsEnabled="False">
                <Viewbox Width="24" Height="24">
                    <Canvas Width="24" Height="24">
                        <!-- Eye outline (almond shape) -->
                        <Path Data="M 1,12 C 5,5 8,4 12,4 C 16,4 19,5 23,12 C 19,19 16,20 12,20 C 8,20 5,19 1,12 Z"
                              Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"
                              StrokeThickness="1.8"
                              Fill="Transparent"
                              StrokeLineJoin="Round" />
                        <!-- Iris ring -->
                        <Ellipse Width="7" Height="7"
                                 Canvas.Left="8.5" Canvas.Top="8.5"
                                 Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"
                                 StrokeThickness="1.5"
                                 Fill="Transparent" />
                        <!-- Pupil -->
                        <Ellipse Width="3" Height="3"
                                 Canvas.Left="10.5" Canvas.Top="10.5"
                                 Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" />
                    </Canvas>
                </Viewbox>
            </ToggleButton>
        </ui:SimpleStackPanel>

        <ui:SimpleStackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical" Spacing="8" Margin="0,0,0,12">
            <TextBlock x:Name="AppTitleText" Text="Email Parser" Style="{StaticResource HeaderTextBlockStyle}" />
            <TextBlock x:Name="AppSubtitleText" Text="IMAP email checker, Hotmail/Outlook account checker, and attachment downloader."
                       Style="{StaticResource BodyTextBlockStyle}" Opacity="0.75" />
        </ui:SimpleStackPanel>

        <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled">
            <Grid>
            <Border x:Name="CheckerPanel" CornerRadius="14" Padding="18"
                    Background="#050505"
                    BorderBrush="#1F1F1F" BorderThickness="1">
                <Grid MinHeight="420">
                    <Border CornerRadius="12" Background="#000000" />

                    <ui:SimpleStackPanel Visibility="Collapsed">
                        <TextBox x:Name="CheckerImapAccountsFileText" />
                        <Button x:Name="BrowseImapAccountsBtn" Click="BrowseImapAccountsBtn_Click" />
                        <TextBox x:Name="CheckerImapProxyFileText" />
                        <Button x:Name="BrowseImapProxyBtn" Click="BrowseImapProxyBtn_Click" />
                        <ComboBox x:Name="CheckerImapProxyProtocolCombo">
                            <ComboBoxItem Content="Socks5" />
                            <ComboBoxItem Content="HTTP" />
                        </ComboBox>
                        <ui:NumberBox x:Name="CheckerMaxParallelText" />
                        <TextBlock x:Name="ResultHintText" />
                    </ui:SimpleStackPanel>

                    <TextBlock Text="Workspace ready"
                               Margin="18,0,0,18"
                               VerticalAlignment="Bottom"
                               Foreground="#4DFFFFFF"
                               FontSize="18"
                               FontWeight="SemiBold" />

                        <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Width="360"
                            Padding="20"
                            CornerRadius="14"
                            Background="#111111"
                            BorderBrush="#2AA8FF"
                            BorderThickness="2">
                        <ui:SimpleStackPanel Orientation="Vertical" Spacing="12">
                            <ui:SimpleStackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="34" Height="34" CornerRadius="17" Background="#1D2F3F">
                                    <ui:SymbolIcon Symbol="Contact" Foreground="#7FD3FF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ui:SimpleStackPanel Orientation="Vertical" Spacing="2">
                                    <TextBlock x:Name="ProductNameValueText" Text="Email Grabber" FontSize="18" FontWeight="SemiBold" Foreground="#F3F3F3" />
                                    <TextBlock x:Name="ProductVersionValueText" Text="DEMO" Foreground="#8FD9FF" />
                                </ui:SimpleStackPanel>
                            </ui:SimpleStackPanel>

                            <Separator Opacity="0.2" />

                            <TextBlock Text="Available modes:" Opacity="0.65" FontSize="12" />

                            <ui:SimpleStackPanel Orientation="Vertical" Spacing="6">
                                <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="24" Height="24" CornerRadius="12" Background="#1A3A1A">
                                        <TextBlock Text="M" FontWeight="Bold" FontSize="11" Foreground="#6FFF6F" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ui:SimpleStackPanel Orientation="Vertical" Spacing="1">
                                        <TextBlock Text="IMAP — valid check" FontWeight="SemiBold" Foreground="#F7F7F7" FontSize="13" />
                                        <TextBlock Text="Checks accounts via IMAP auth. Max 50 threads." Foreground="#888" FontSize="11" />
                                    </ui:SimpleStackPanel>
                                </ui:SimpleStackPanel>
                                <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="24" Height="24" CornerRadius="12" Background="#1A3A1A">
                                        <TextBlock Text="H" FontWeight="Bold" FontSize="11" Foreground="#6FFF6F" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ui:SimpleStackPanel Orientation="Vertical" Spacing="1">
                                        <TextBlock Text="Hotmail — valid check" FontWeight="SemiBold" Foreground="#F7F7F7" FontSize="13" />
                                        <TextBlock Text="Checks Outlook accounts via Web API. Max 50 threads." Foreground="#888" FontSize="11" />
                                    </ui:SimpleStackPanel>
                                </ui:SimpleStackPanel>
                            </ui:SimpleStackPanel>

                            <Separator Opacity="0.2" />

                            <TextBlock Text="Other features (OneDrive, Crypto Key, Anti-Public, email download, attachment download, seed parsing) are not available in the DEMO version."
                                       Foreground="#666" FontSize="11" TextWrapping="Wrap" />
                        </ui:SimpleStackPanel>
                    </Border>

                    <!-- Hidden fields required by code-behind — not visible to user -->
                    <ui:SimpleStackPanel Visibility="Collapsed">
                        <TextBlock x:Name="LicenseStatusValueText" />
                        <TextBlock x:Name="LicenseKeyValueText" />
                        <TextBlock x:Name="LicenseDaysLeftValueText" />
                        <TextBlock x:Name="LicenseExpiryValueText" />
                    </ui:SimpleStackPanel>
                </Grid>
            </Border>

            <Border x:Name="UploadPanel" CornerRadius="14" Padding="18" Visibility="Collapsed"
                    Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
                <ui:SimpleStackPanel Orientation="Vertical" Spacing="10">
                    <TextBlock Text="Mix Email" Style="{StaticResource TitleTextBlockStyle}" />

                    <TextBlock Text="IMAP: download attachments from INBOX, Sent and Deleted." Opacity="0.75" />

                    <TextBlock Text="Accounts (imap_accounts.txt)" Opacity="0.75" />
                    <DockPanel LastChildFill="True">
                        <TextBox x:Name="UploadImapAccountsFileText" MinHeight="40" IsReadOnly="True" VerticalContentAlignment="Center" />
                        <Button x:Name="BrowseUploadImapAccountsBtn" MinHeight="40" Margin="10,0,0,0" Click="BrowseUploadImapAccountsBtn_Click">
                            <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                                <ui:SymbolIcon Symbol="Folder" />
                                <TextBlock Text="Browse" />
                            </ui:SimpleStackPanel>
                        </Button>
                    </DockPanel>

                    <TextBlock Text="Proxy (optional)" Opacity="0.75" />
                    <DockPanel LastChildFill="True">
                        <TextBox x:Name="UploadImapProxyFileText" MinHeight="40" IsReadOnly="True" VerticalContentAlignment="Center" />
                        <Button x:Name="BrowseUploadImapProxyBtn" MinHeight="40" Margin="10,0,0,0" Click="BrowseUploadImapProxyBtn_Click">
                            <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                                <ui:SymbolIcon Symbol="Folder" />
                                <TextBlock Text="Add" />
                            </ui:SimpleStackPanel>
                        </Button>
                    </DockPanel>

                    <TextBlock Text="Proxy protocol" Opacity="0.75" />
                    <ComboBox x:Name="UploadImapProxyProtocolCombo" MinHeight="40" SelectedIndex="0">
                        <ComboBoxItem Content="Socks5" />
                        <ComboBoxItem Content="HTTP" />
                    </ComboBox>

                    <!-- Disabled features (not available in DEMO) -->
                    <ui:SimpleStackPanel IsEnabled="False" Opacity="0.35">
                        <CheckBox x:Name="UploadScanSeedsChk" Content="Parsing Seed phrase / Private Key (not available in DEMO)" />
                        <CheckBox x:Name="UploadDownloadAttachmentsChk" Content="Download attachments (not available in DEMO)" />
                        <CheckBox x:Name="UploadDownloadEmailsChk" Content="Download emails by keyword (not available in DEMO)" Margin="0,8,0,0" />

                        <TextBlock Text="Email filter" Opacity="0.75" Margin="0,8,0,0" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="UploadFilterModeCombo" MinHeight="40" SelectedIndex="0" Grid.Column="0">
                                <ComboBoxItem Content="All emails" />
                                <ComboBoxItem Content="By sender" />
                                <ComboBoxItem Content="By subject" />
                                <ComboBoxItem Content="Sender or subject" />
                            </ComboBox>
                            <TextBlock Grid.Column="1" Text="From date" Opacity="0.75" VerticalAlignment="Center" Margin="12,0,8,0" />
                            <ui:SimpleStackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                <ui:NumberBox x:Name="UploadEmailFromDayText" MinHeight="40" Minimum="1" Maximum="31" Value="1" SmallChange="1" SpinButtonPlacementMode="Inline" />
                                <ui:NumberBox x:Name="UploadEmailFromMonthText" MinHeight="40" Minimum="1" Maximum="12" Value="1" SmallChange="1" SpinButtonPlacementMode="Inline" />
                                <ui:NumberBox x:Name="UploadEmailFromYearText" MinHeight="40" Minimum="2000" Maximum="2026" Value="2000" SmallChange="1" SpinButtonPlacementMode="Inline" />
                            </ui:SimpleStackPanel>
                        </Grid>

                        <TextBlock Text="Sender keywords (comma-separated)" Opacity="0.75" />
                        <TextBox x:Name="UploadSenderKeywordsText" MinHeight="40" VerticalContentAlignment="Center" />

                        <TextBlock Text="Subject keywords (comma-separated)" Opacity="0.75" />
                        <TextBox x:Name="UploadSubjectKeywordsText" MinHeight="40" VerticalContentAlignment="Center" />

                        <TextBlock Text="Extension filter" Opacity="0.75" Margin="0,8,0,0" />
                        <WrapPanel>
                            <CheckBox x:Name="UploadExtAllChk" Content="All" Margin="0,0,12,8" />
                            <CheckBox x:Name="UploadExtPdfChk" Content=".pdf" Margin="0,0,12,8" />
                            <CheckBox x:Name="UploadExtPngChk" Content=".png" Margin="0,0,12,8" />
                            <CheckBox x:Name="UploadExtJpgChk" Content=".jpg" Margin="0,0,12,8" />
                            <CheckBox x:Name="UploadExtJpegChk" Content=".jpeg" Margin="0,0,12,8" />
                            <CheckBox x:Name="UploadExtHeicChk" Content=".HEIC" Margin="0,0,12,8" />
                            <CheckBox x:Name="UploadExtIosChk" Content=".IOS" Margin="0,0,12,8" />
                            <CheckBox x:Name="UploadExtZipChk" Content=".zip" Margin="0,0,12,8" />
                            <CheckBox x:Name="UploadExtRarChk" Content=".rar" Margin="0,0,12,8" />
                            <CheckBox x:Name="UploadExtTxtChk" Content=".txt" Margin="0,0,12,8" />
                            <CheckBox x:Name="UploadExtXlsChk" Content=".XLS" Margin="0,0,12,8" />
                            <CheckBox x:Name="UploadExtXlsxChk" Content=".XLSX" Margin="0,0,12,8" />
                            <CheckBox x:Name="UploadExtDocChk" Content=".doc" Margin="0,0,12,8" />
                            <CheckBox x:Name="UploadExtDocxChk" Content=".docx" Margin="0,0,12,8" />
                        </WrapPanel>
                    </ui:SimpleStackPanel>

                    <TextBlock Text="Threads (max 50)" Opacity="0.75" />
                    <ui:NumberBox x:Name="MaxParallelUploadText" MinHeight="40" Minimum="1" Maximum="50" SpinButtonPlacementMode="Inline" />

                    <TextBlock Text="Result: Result/Valid_Email.txt next to the app." Opacity="0.75" Margin="0,8,0,0" />
                </ui:SimpleStackPanel>
            </Border>

            <Border x:Name="HotmailPanel" CornerRadius="14" Padding="18" Visibility="Collapsed"
                    Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
                <ui:SimpleStackPanel Orientation="Vertical" Spacing="10">
                    <TextBlock Text="Hotmail" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="Outlook Web API: check accounts and download emails." Opacity="0.75" />

                    <TextBlock Text="Accounts (hotmail_accounts.txt)" Opacity="0.75" />
                    <DockPanel LastChildFill="True">
                        <TextBox x:Name="HotmailAccountsFileText" MinHeight="40" IsReadOnly="True" VerticalContentAlignment="Center" />
                        <Button x:Name="BrowseHotmailAccountsBtn" MinHeight="40" Margin="10,0,0,0" Click="BrowseHotmailAccountsBtn_Click">
                            <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                                <ui:SymbolIcon Symbol="Folder" />
                                <TextBlock Text="Browse" />
                            </ui:SimpleStackPanel>
                        </Button>
                    </DockPanel>

                    <TextBlock Text="Proxy (optional)" Opacity="0.75" />
                    <DockPanel LastChildFill="True">
                        <TextBox x:Name="HotmailProxyFileText" MinHeight="40" IsReadOnly="True" VerticalContentAlignment="Center" />
                        <Button x:Name="BrowseHotmailProxyBtn" MinHeight="40" Margin="10,0,0,0" Click="BrowseHotmailProxyBtn_Click">
                            <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                                <ui:SymbolIcon Symbol="Folder" />
                                <TextBlock Text="Add" />
                            </ui:SimpleStackPanel>
                        </Button>
                    </DockPanel>

                    <TextBlock Text="Proxy protocol" Opacity="0.75" />
                    <ComboBox x:Name="HotmailProxyProtocolCombo" MinHeight="40" SelectedIndex="0">
                        <ComboBoxItem Content="Socks5" />
                        <ComboBoxItem Content="HTTP" />
                    </ComboBox>

                    <TextBlock Text="Threads (max 50)" Opacity="0.75" />
                    <ui:NumberBox x:Name="HotmailMaxParallelText" MinHeight="40" Minimum="1" Maximum="50" SpinButtonPlacementMode="Inline" />

                    <!-- Disabled features (not available in DEMO) -->
                    <ui:SimpleStackPanel IsEnabled="False" Opacity="0.35">
                        <TextBlock Text="Download threads" Opacity="0.75" />
                        <ui:NumberBox x:Name="HotmailDownloadThreadsText" MinHeight="40" Minimum="1" Maximum="50" SpinButtonPlacementMode="Inline" />

                        <CheckBox x:Name="HotmailDownloadEmailsChk" Content="Download emails (not available in DEMO)" />
                        <CheckBox x:Name="HotmailDownloadAttachmentsChk" Content="Download attachments (not available in DEMO)" />
                        <CheckBox x:Name="HotmailScanSeedsChk" Content="Scan seed/keys (not available in DEMO)" />

                        <TextBlock Text="Max attachment size (KB, 0 = no limit)" Opacity="0.75" />
                        <ui:NumberBox x:Name="HotmailAttachmentMaxSizeText" MinHeight="40" Minimum="0" Maximum="204800" SpinButtonPlacementMode="Inline" />

                        <TextBlock Text="Extension filter (comma-separated)" Opacity="0.75" />
                        <TextBox x:Name="HotmailAttachmentExtensionsText" MinHeight="40" VerticalContentAlignment="Center" />

                        <TextBlock Text="Folders" Opacity="0.75" />
                        <WrapPanel>
                            <CheckBox x:Name="HotmailFolderInboxChk" Content="Inbox" Margin="0,0,12,8" />
                            <CheckBox x:Name="HotmailFolderSentChk" Content="Sent" Margin="0,0,12,8" />
                            <CheckBox x:Name="HotmailFolderDraftsChk" Content="Drafts" Margin="0,0,12,8" />
                        </WrapPanel>

                        <TextBlock Text="Email filter" Opacity="0.75" />
                        <ComboBox x:Name="HotmailFilterModeCombo" MinHeight="40" SelectedIndex="0">
                            <ComboBoxItem Content="All emails" />
                            <ComboBoxItem Content="By sender" />
                            <ComboBoxItem Content="By subject" />
                            <ComboBoxItem Content="Sender or subject" />
                        </ComboBox>

                        <TextBlock Text="Sender keywords (comma-separated)" Opacity="0.75" />
                        <TextBox x:Name="HotmailSenderKeywordsText" MinHeight="40" VerticalContentAlignment="Center" />

                        <TextBlock Text="Subject keywords (comma-separated)" Opacity="0.75" />
                        <TextBox x:Name="HotmailSubjectKeywordsText" MinHeight="40" VerticalContentAlignment="Center" />
                    </ui:SimpleStackPanel>

                    <TextBlock Text="Result: Result/Hotmail_... folder next to the app." Opacity="0.75" Margin="0,8,0,0" />
                </ui:SimpleStackPanel>
            </Border>

            <Border x:Name="OneDrivePanel" CornerRadius="14" Padding="18" Visibility="Collapsed"
                    Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
                <ui:SimpleStackPanel Orientation="Vertical" Spacing="10">
                    <TextBlock Text="OneDrive" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="OneDrive: check accounts, list files, download from cloud." Opacity="0.75" />

                    <TextBlock Text="Accounts (onedrive_accounts.txt)" Opacity="0.75" />
                    <DockPanel LastChildFill="True">
                        <TextBox x:Name="OneDriveAccountsFileText" MinHeight="40" IsReadOnly="True" VerticalContentAlignment="Center" />
                        <Button x:Name="BrowseOneDriveAccountsBtn" MinHeight="40" Margin="10,0,0,0" Click="BrowseOneDriveAccountsBtn_Click">
                            <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                                <ui:SymbolIcon Symbol="Folder" />
                                <TextBlock Text="Browse" />
                            </ui:SimpleStackPanel>
                        </Button>
                    </DockPanel>

                    <TextBlock Text="Proxy (optional)" Opacity="0.75" />
                    <DockPanel LastChildFill="True">
                        <TextBox x:Name="OneDriveProxyFileText" MinHeight="40" IsReadOnly="True" VerticalContentAlignment="Center" />
                        <Button x:Name="BrowseOneDriveProxyBtn" MinHeight="40" Margin="10,0,0,0" Click="BrowseOneDriveProxyBtn_Click">
                            <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                                <ui:SymbolIcon Symbol="Folder" />
                                <TextBlock Text="Add" />
                            </ui:SimpleStackPanel>
                        </Button>
                    </DockPanel>

                    <TextBlock Text="Proxy protocol" Opacity="0.75" />
                    <ComboBox x:Name="OneDriveProxyProtocolCombo" MinHeight="40" SelectedIndex="0">
                        <ComboBoxItem Content="Socks5" />
                        <ComboBoxItem Content="HTTP" />
                    </ComboBox>

                    <TextBlock Text="Threads (checker)" Opacity="0.75" />
                    <ui:NumberBox x:Name="OneDriveMaxParallelText" MinHeight="40" Minimum="1" Maximum="3000" SpinButtonPlacementMode="Inline" />

                    <TextBlock Text="Threads (download)" Opacity="0.75" />
                    <ui:NumberBox x:Name="OneDriveDownloadThreadsText" MinHeight="40" Minimum="1" Maximum="45" SpinButtonPlacementMode="Inline" />

                    <TextBlock Text="Main mode" Opacity="0.75" />
                    <ComboBox x:Name="OneDriveMainModeCombo" MinHeight="40" SelectedIndex="0">
                        <ComboBoxItem Content="Download files" />
                        <ComboBoxItem Content="No download" />
                    </ComboBox>

                    <TextBlock Text="Sub mode" Opacity="0.75" />
                    <ComboBox x:Name="OneDriveSubModeCombo" MinHeight="40" SelectedIndex="0">
                        <ComboBoxItem Content="By extensions" />
                        <ComboBoxItem Content="By keywords" />
                        <ComboBoxItem Content="By extensions + keywords" />
                        <ComboBoxItem Content="Internal search (API)" />
                    </ComboBox>

                    <TextBlock Text="Extensions / Keywords (comma-separated)" Opacity="0.75" />
                    <TextBox x:Name="OneDriveFilterText" MinHeight="40" VerticalContentAlignment="Center" />

                    <TextBlock Text="Max file size (KB, 0 = no limit)" Opacity="0.75" />
                    <ui:NumberBox x:Name="OneDriveMaxSizeText" MinHeight="40" Minimum="0" Maximum="10485760" SpinButtonPlacementMode="Inline" />

                    <CheckBox x:Name="OneDriveScanSeedsChk" Content="Scan seed/keys" IsChecked="True" />

                    <TextBlock Text="Result: Result folder next to the app." Opacity="0.75" Margin="0,8,0,0" />
                </ui:SimpleStackPanel>
            </Border>

            <Border x:Name="CryptoKeyPanel" CornerRadius="14" Padding="18" Visibility="Collapsed"
                    Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
                <ui:SimpleStackPanel Orientation="Vertical" Spacing="10">
                    <TextBlock Text="Photo Seed / Private Key" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="Scan a photo folder or a single image file. Results are written to the Result folder in real time."
                               Opacity="0.75" />

                    <TextBlock Text="Photos path" Opacity="0.75" />
                    <DockPanel LastChildFill="True">
                        <TextBox x:Name="CryptoKeySourcePathText"
                                 MinHeight="40"
                                 VerticalContentAlignment="Center"
                                 LostFocus="CryptoKeyInput_LostFocus" />
                        <Button x:Name="BrowseCryptoKeySourceBtn" MinHeight="40" Margin="10,0,0,0" Click="BrowseCryptoKeySourceBtn_Click">
                            <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                                <ui:SymbolIcon Symbol="Folder" />
                                <TextBlock Text="Browse folder" />
                            </ui:SimpleStackPanel>
                        </Button>
                    </DockPanel>

                    <TextBlock Text="Workers" Opacity="0.75" />
                    <ui:NumberBox x:Name="CryptoKeyWorkersText"
                                  MinHeight="40"
                                  Minimum="1"
                                  Maximum="64"
                                  Value="4"
                                  SpinButtonPlacementMode="Inline"
                                  LostFocus="CryptoKeyInput_LostFocus" />

                    <TextBlock Text="Log shows only images where a seed phrase or private key was found."
                               Opacity="0.75"
                               Margin="0,8,0,0" />
                    <TextBlock Text="Result: Result\PhotoSeed&amp;PK_DD_MM_YYYY_HH_MM_SS"
                               Opacity="0.75" />
                </ui:SimpleStackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════════ -->
            <!-- Anti-Public panel                                                   -->
            <!-- ═══════════════════════════════════════════════════════════════════ -->
            <Border x:Name="AntiPublicPanel" CornerRadius="14" Padding="18" Visibility="Collapsed"
                    Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
                <ui:SimpleStackPanel Orientation="Vertical" Spacing="10">
                    <TextBlock Text="Anti-Public" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="Analyze a photo folder and extract visual feature fingerprints. Results accumulate in a persistent text file across multiple runs."
                               Opacity="0.75" TextWrapping="Wrap" />

                    <TextBlock Text="Photos folder" Opacity="0.75" Margin="0,6,0,0" />
                    <DockPanel LastChildFill="True">
                        <TextBox x:Name="AntiPublicSourcePathText"
                                 MinHeight="40"
                                 VerticalContentAlignment="Center"
                                 LostFocus="AntiPublicInput_LostFocus" />
                        <Button x:Name="BrowseAntiPublicSourceBtn" MinHeight="40" Margin="10,0,0,0" Click="BrowseAntiPublicSourceBtn_Click">
                            <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                                <ui:SymbolIcon Symbol="Folder" />
                                <TextBlock Text="Browse folder" />
                            </ui:SimpleStackPanel>
                        </Button>
                    </DockPanel>

                    <TextBlock Text="Workers" Opacity="0.75" />
                    <ui:NumberBox x:Name="AntiPublicWorkersText"
                                  MinHeight="40"
                                  Minimum="1"
                                  Maximum="16"
                                  Value="4"
                                  SpinButtonPlacementMode="Inline"
                                  LostFocus="AntiPublicInput_LostFocus" />


                    <Border CornerRadius="8" Padding="12" Margin="0,6,0,0"
                            Background="#0D0D0D" BorderBrush="#2A2A2A" BorderThickness="1">
                        <ui:SimpleStackPanel Orientation="Vertical" Spacing="6">
                            <TextBlock Text="How it works:" FontWeight="SemiBold" Foreground="#C0C0C0" />
                            <TextBlock Foreground="#808080" TextWrapping="Wrap" FontSize="12">
                                <Run Text="1st run (empty database):" FontWeight="SemiBold" Foreground="#7FC0FF" /><LineBreak />
                                <Run Text="   Scans folder, saves features + pHash/dHash for every image." /><LineBreak />
                                <Run Text="   Nothing is moved — the database is built." /><LineBreak /><LineBreak />
                                <Run Text="Next runs:" FontWeight="SemiBold" Foreground="#7FC0FF" /><LineBreak />
                                <Run Text="   Each image is compared against the saved database." /><LineBreak />
                                <Run Text="   FOUND in database  → known, stays in place." /><LineBreak />
                                <Run Text="   NOT in database → Anti-Public → moved to Result\Anti-Public_..." />
                            </TextBlock>
                        </ui:SimpleStackPanel>
                    </Border>

                    <TextBlock Opacity="0.65" Margin="0,6,0,0" TextWrapping="Wrap"
                               Text="Database: AntiPublic\ next to the .exe (not in Result — survives cleanup)." />
                </ui:SimpleStackPanel>
            </Border>
            </Grid>
        </ScrollViewer>

        <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:SimpleStackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <Button x:Name="StartBtn" MinWidth="140" MinHeight="42" Click="StartBtn_Click" Style="{StaticResource AccentButtonStyle}">
                        <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                            <ui:SymbolIcon Symbol="Play" />
                            <TextBlock x:Name="StartBtnLabel" Text="Start" />
                        </ui:SimpleStackPanel>
                    </Button>

                    <Button x:Name="CancelBtn" MinWidth="140" MinHeight="42" IsEnabled="False" Click="CancelBtn_Click">
                        <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                            <ui:SymbolIcon Symbol="Stop" />
                            <TextBlock Text="Stop" />
                        </ui:SimpleStackPanel>
                    </Button>

                    <Button x:Name="OpenOutputBtn" MinWidth="180" MinHeight="42" Click="OpenOutputBtn_Click">
                        <ui:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                            <ui:SymbolIcon Symbol="OpenFile" />
                            <TextBlock Text="Open result" />
                        </ui:SimpleStackPanel>
                    </Button>
                </ui:SimpleStackPanel>

                <ui:SimpleStackPanel Grid.Column="1" Orientation="Vertical" Spacing="6" HorizontalAlignment="Right">
                    <TextBlock x:Name="StatusText" Text="Ready" Opacity="0.75" HorizontalAlignment="Right" />
                    <ProgressBar x:Name="Progress" Height="6" Width="360" Minimum="0" Maximum="100" Value="0" />
                </ui:SimpleStackPanel>
        </Grid>

        <Border Grid.Row="3" Grid.Column="1" CornerRadius="14" Padding="14"
                Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Log" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,8" />
                <TextBox x:Name="LogBox" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled" />
            </Grid>
        </Border>

        <TextBlock x:Name="FooterNoteText" Grid.Row="4" Grid.Column="1" Opacity="0.65" Margin="2,12,0,0"
                   Text="Note: IMAP servers are loaded from imap_servers.txt next to the app." />
    </Grid>
</Window>
